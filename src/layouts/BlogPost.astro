---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const data = Astro.props.frontmatter || Astro.props;
const { title, jalaliDate, tags } = data;

// Fetch all posts to generate the footer tags/archives
const allPosts = await getCollection('blog');
// Fetch all comments and tally them up by postSlug
const allComments = await getCollection('comments');
const commentCounts: Record<string, number> = {};

allComments.forEach(comment => {
    const slug = comment.data.postSlug;
    commentCounts[slug] = (commentCounts[slug] || 0) + 1;
});
const tagCounts: Record<string, number> = {};
const archiveCounts: Record<string, number> = {};

allPosts.forEach(post => {
    if (post.data.tags) {
        post.data.tags.forEach(tag => {
            tagCounts[tag] = (tagCounts[tag] || 0) + 1;
        });
    }
    let archiveLabel = "نامشخص";
    if (post.data.jalaliDate) {
        const parts = post.data.jalaliDate.split(" ");
        if (parts.length >= 3) {
            archiveLabel = `${parts[1]} ${parts[2]}`; 
        }
    }
    archiveCounts[archiveLabel] = (archiveCounts[archiveLabel] || 0) + 1;
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const sortedArchives = Object.keys(archiveCounts).map(label => ({
    label,
    count: archiveCounts[label]
}));

function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | دلشرم</title>
    
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
    <link rel="alternate" type="application/rss+xml" title="وب‌نوشت‌های دلشرم" href="/delsharm/rss.xml" />
    <meta name="google-site-verification" content="mg8IXQt3fbDtkRvs5Hq58jPSIh9-F7Otxg64p517cvY" />
</head>
<body>
    <div class="single-post-container">
        
        <div class="page-header">
            <div class="header-right">
                <a href="/delsharm/rss.xml" target="_blank" title="اشتراک RSS" class="rss-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 11a9 9 0 0 1 9 9"></path>
                        <path d="M4 4a16 16 0 0 1 16 16"></path>
                        <circle cx="5" cy="19" r="1"></circle>
                    </svg>
                    <span class="rss-text" dir="ltr">RSS</span>
                </a>
            </div>

<div class="header-center">
    <h1><a href="/delsharm/" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
    <p><a href="/delsharm/about" style="text-decoration: underline; color: inherit;">محمدصادق رسولی</a></p>
    
    <!-- Fast Links Section -->
    <div style="margin-top: 10px; display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; font-size: 0.85em;">
        <a href="/delsharm/tags/قفسه‌نوشت/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            قفسه‌نوشت
        </a>
        <a href="/delsharm/tags/سیاه‌مشق/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            سیاه‌مشق
        </a>
        <a href="/delsharm/tags/سفرنامهٔ نیویورک/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            سفرنامهٔ نیویورک
        </a>
        <a href="/delsharm/tags/شرابه‌های سفر/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            شرابه‌های سفر
        </a>
        <a href="/delsharm/tags/یادداشت‌های پراکنده/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            یادداشت‌های پراکنده
        </a>
    </div>
</div>

            <div class="header-left">
                <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم" style="margin: 0;">🌙</button>
            </div>
        </div>
        <a href="/delsharm" style="display: inline-block; margin-bottom: 20px; font-weight: bold;">← بازگشت به صفحه اصلی</a>
        
        <h2 style="border-bottom: 2px solid var(--border-color); padding-bottom: 15px; margin-top: 10px;">{title}</h2>
        
        {jalaliDate && (
            <div class="date" style="color: var(--text-muted); font-size: 0.9em; margin-bottom: 20px;">
                {jalaliDate}
            </div>
        )}
        
        <div class="post-content-body">
            <slot />
        </div>
        
        {tags && tags.length > 0 && (
            <div class="post-tags">
                <strong>برچسب‌ها:</strong>
                {tags.map((tag: string) => (
                    <a href={`/delsharm/tags/${tag}`} style="margin-left: 10px; color: #2980b9;">{tag}</a>
                ))}
            </div>
        )}
        
        <div class="subpage-footer" style="margin-top: 80px; padding-top: 40px; border-top: 2px solid var(--border-color);">
            <h3 style="color: var(--text-heading); margin-bottom: 20px; font-size: 1.3em;">موضوعات پرطرفدار</h3>
            <div class="tags-grid">
                {sortedTags.map(([tag, count]) => (
                    <a href={`/delsharm/tags/${tag}/`} class="tag-tile">
                        <span class="tag-name">{tag}</span>
                        <span class="tag-count">{toFa(count)}</span>
                    </a>
                ))}
            </div>
            <h3 style="color: var(--text-heading); margin-top: 40px; margin-bottom: 20px; font-size: 1.3em;">بایگانی ماهانه</h3>
            <div class="tags-grid">
                {sortedArchives.map(archive => (
                    <a href="#" class="baygani-tile">
                        <span class="tag-name">{archive.label}</span>
                        <span class="tag-count">{toFa(archive.count)}</span>
                    </a>
                ))}
            </div>
        </div>
        
    </div> <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        
        updateIcon();
        
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
    
    <script data-goatcounter="https://delsharm.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</body>

<style is:global>
    article a {
        color: #3498db;
        text-decoration: none;
        border-bottom: 2px solid #3498db; 
        transition: all 0.2s ease;
        font-weight: bold;
    }

    article a:hover {
        color: #2980b9;
        border-bottom-color: #2980b9;
        background-color: rgba(52, 152, 219, 0.1); 
    }
</style>
</html>