<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>دلشرم {currentPage > 1 ? `- صفحه ${toFa(currentPage)}` : ''}</title>
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم">🌙</button>
            <h1><a href="/delsharm/" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
            <p style="color: var(--text-muted); margin-top: 10px; font-size: 1.1em;">محمدصادق رسولی</p>
        </div>
        
        <div class="main-layout">
            <div class="content-area">
                <div class="section-title" style="margin-top: 0;">آخرین نوشته‌ها</div>
                
                <div class="posts-grid">
                    
                    {page.data[0] && (
                        <div class="post-card">
                            {extractImage(page.data[0].body) && (
                                <a href={`/delsharm/blog/${page.data[0].id}/`}>
                                    <img src={extractImage(page.data[0].body)} class="card-img" alt="تصویر پست" />
                                </a>
                            )}
                            <div class="card-content" style="display: flex; flex-direction: column; flex-grow: 1;">
                                <h2><a href={`/delsharm/blog/${page.data[0].id}/`}>{page.data[0].data.title}</a></h2>
                                
                                <div class="meta-row" style="margin-bottom: 15px;">
                                    {page.data[0].data.jalaliDate && <div class="date" style="margin-bottom: 0;">{page.data[0].data.jalaliDate}</div>}
                                </div>

                                <div class="excerpt-container" set:html={generateExcerpt(page.data[0].body)}></div>
                                
                                <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 20px;">                                   
                                 <a href={`/delsharm/blog/${page.data[0].id}/`} class="read-more" style="margin-top: 0;">ادامه مطلب ←</a>
                                                                    
                                    <div class="comment-badge" style="font-size: 0.85em; color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 2px 8px; border-radius: 12px; font-weight: bold;">
                                        💬 {commentCounts[page.data[0].id] ? toFa(commentCounts[page.data[0].id]) : '۰'} دیدگاه
                                    </div>
                                </div>
                            </div>
                        </div>
                    )}

                    <div class="top-widgets-area full-width-banner mobile-banner">
                        <div class="widget-column">
                            <div class="section-title" style="margin-top: 0; font-size: 1.2em; border-bottom: none; padding-bottom: 0;">موضوعات پربسامد</div>
                            <div class="tags-grid" style="margin-bottom: 0;">
                                {sortedTags.map(([tag, count]) => (
                                    <a href={`/delsharm/tags/${tag}/`} class="tag-tile">
                                        <span class="tag-name">{tag}</span>
                                        <span class="tag-count">{toFa(count)}</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                        <div class="widget-column">
                            <div class="section-title" style="margin-top: 0; font-size: 1.2em; border-bottom: none; padding-bottom: 0;">بایگانی ماهانه</div>
                            <div class="tags-grid" style="margin-bottom: 0;">
                                {sortedArchives.map(archive => (
                                    <a href={`/delsharm/baygani/${archive.label}/`} class="baygani-tile">
                                        <span class="tag-name">{archive.label}</span>
                                        <span class="tag-count">{toFa(archive.count)}</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>

                    {page.data.slice(1, 3).map((post) => (
                        <div class="post-card">
                            {extractImage(post.body) && (
                                <a href={`/delsharm/blog/${post.id}/`}>
                                    <img src={extractImage(post.body)} class="card-img" alt="تصویر پست" />
                                </a>
                            )}
                            <div class="card-content" style="display: flex; flex-direction: column; flex-grow: 1;">
                                <h2><a href={`/delsharm/blog/${post.id}/`}>{post.data.title}</a></h2>
                                
                                <div class="meta-row" style="margin-bottom: 15px;">
                                    {post.data.jalaliDate && <div class="date" style="margin-bottom: 0;">{post.data.jalaliDate}</div>}
                                </div>

                                <div class="excerpt-container" set:html={generateExcerpt(post.body)}></div>
                                
                                <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 20px;">
                                    <a href={`/delsharm/blog/${post.id}/`} class="read-more" style="margin-top: 0;">ادامه مطلب ←</a>
                                    
                                    <div class="comment-badge" style="font-size: 0.85em; color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 2px 8px; border-radius: 12px; font-weight: bold;">
                                        💬 {commentCounts[post.id] ? toFa(commentCounts[post.id]) : '۰'} دیدگاه
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}

                    <div class="top-widgets-area full-width-banner desktop-banner">
                        <div class="widget-column">
                            <div class="section-title" style="margin-top: 0; font-size: 1.2em; border-bottom: none; padding-bottom: 0;">موضوعات پربسامد</div>
                            <div class="tags-grid" style="margin-bottom: 0;">
                                {sortedTags.map(([tag, count]) => (
                                    <a href={`/delsharm/tags/${tag}/`} class="tag-tile">
                                        <span class="tag-name">{tag}</span>
                                        <span class="tag-count">{toFa(count)}</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                        <div class="widget-column">
                            <div class="section-title" style="margin-top: 0; font-size: 1.2em; border-bottom: none; padding-bottom: 0;">بایگانی ماهانه</div>
                            <div class="tags-grid" style="margin-bottom: 0;">
                                {sortedArchives.map(archive => (
                                    <a href={`/delsharm/baygani/${archive.label}/`} class="baygani-tile">
                                        <span class="tag-name">{archive.label}</span>
                                        <span class="tag-count">{toFa(archive.count)}</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>

                    {page.data.slice(3).map((post) => (
                        <div class="post-card">
                            {extractImage(post.body) && (
                                <a href={`/delsharm/blog/${post.id}/`}>
                                    <img src={extractImage(post.body)} class="card-img" alt="تصویر پست" />
                                </a>
                            )}
                            <div class="card-content" style="display: flex; flex-direction: column; flex-grow: 1;">
                                    <h2><a href={`/delsharm/blog/${post.id}/`}>{post.data.title}</a></h2>
                                    
                                    <div class="meta-row" style="margin-bottom: 15px;">
                                        {post.data.jalaliDate && <div class="date" style="margin-bottom: 0;">{post.data.jalaliDate}</div>}
                                    </div>

                                    <div class="excerpt-container" set:html={generateExcerpt(post.body)}></div>
                                    
                                    <!-- Notice the margin-top: auto; added here! -->
                                    <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 20px;">
                                        <a href={`/delsharm/blog/${post.id}/`} class="read-more" style="margin-top: 0;">ادامه مطلب ←</a>
                                        
                                        <div class="comment-badge" style="font-size: 0.85em; color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 2px 8px; border-radius: 12px; font-weight: bold;">
                                            💬 {commentCounts[post.id] ? toFa(commentCounts[post.id]) : '۰'} دیدگاه
                                        </div>
                                    </div>
                                </div>
                        </div>
                    ))}
                    
                </div>

                {totalPages > 1 && (
                    <div class="pagination">
                        {page.url.prev ? <a href={page.url.prev}>→ جدیدتر</a> : <span></span>}
                        
                        <div class="page-numbers">
                            {pageNumbers.map((num) => (
                                num === '...' ? <span>...</span> :
                                num === currentPage ? <span class="current-page">{toFa(Number(num))}</span> :
                                <a href={num === 1 ? '/delsharm/' : `/delsharm/${num}`}>{toFa(Number(num))}</a>
                            ))}
                        </div>

                        {page.url.next ? <a href={page.url.next}>قدیمی‌تر ←</a> : <span></span>}
                    </div>
                )}
            </div>
        </div>
    </div>
    
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        updateIcon();
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>