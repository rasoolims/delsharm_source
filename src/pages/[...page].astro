import { getCollection } from 'astro:content';
import '../styles/global.css';

export async function getStaticPaths({ paginate }) {
    const rawPosts = await getCollection('blog');
    
    // Ultra-safe sort
    const sortedPosts = rawPosts.sort((a, b) => {
        const dateA = (a.data && a.data.date) ? new Date(a.data.date).getTime() : 0;
        const dateB = (b.data && b.data.date) ? new Date(b.data.date).getTime() : 0;
        return dateB - dateA;
    });
    
    // 15 posts creates exactly five 3-column rows
    return paginate(sortedPosts, { pageSize: 15 });
}

const { page } = Astro.props;
const allPosts = await getCollection('blog');

// --- TAGS & ARCHIVES LOGIC ---
const tagCounts: Record<string, number> = {};
const archiveCounts: Record<string, number> = {};

allPosts.forEach(post => {
    const title = post.data.title || "—";
    const tags = post.data.tags ? [...post.data.tags] : [];
    
    if (title === "—" && !tags.includes("سیاه‌مشق")) {
        tags.push("سیاه‌مشق");
    }

    tags.forEach(tag => {
        tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });

    let archiveLabel = "نامشخص";
    if (post.data.jalaliDate) {
        const parts = post.data.jalaliDate.split(" ");
        if (parts.length >= 3) {
            archiveLabel = `${parts[1]} ${parts[2]}`; 
        }
    }
    archiveCounts[archiveLabel] = (archiveCounts[archiveLabel] || 0) + 1;
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);

const persianMonths = [
    "فروردین", "اردیبهشت", "خرداد", "تیر", "مرداد", "شهریور",
    "مهر", "آبان", "آذر", "دی", "بهمن", "اسفند"
];

function getArchiveSortValue(label: string) {
    if (label === "نامشخص") return 0;
    const parts = label.split(" ");
    if (parts.length !== 2) return 0;
    
    const monthName = parts[0];
    const yearStr = parts[1];
    
    const enYear = yearStr.replace(/[۰-۹]/g, (w) => '۰۱۲۳۴۵۶۷۸۹'.indexOf(w).toString());
    const year = parseInt(enYear, 10);
    const monthIndex = persianMonths.indexOf(monthName);
    
    if (isNaN(year) || monthIndex === -1) return 0;
    return (year * 100) + monthIndex;
}

const sortedArchives = Object.keys(archiveCounts).map(label => ({
    label,
    count: archiveCounts[label]
})).sort((a, b) => getArchiveSortValue(b.label) - getArchiveSortValue(a.label));

// --- COMMENTS LOGIC ---
const allComments = await getCollection('comments');
const commentCounts: Record<string, number> = {};

allComments.forEach(comment => {
    const slug = comment.data.postSlug;
    commentCounts[slug] = (commentCounts[slug] || 0) + 1;
});

// --- HELPERS ---
function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}

function extractImage(bodyStr: string) {
    const imgRegex = /\x3Cimg[^\x3E]+src=["'](.*?)["']|!\[.*?\]\((.*?)\)/i;
    const match = bodyStr.match(imgRegex);
    return match ? (match[1] || match[2]) : null;
}

function generateExcerpt(markdownBody: string) {
    if (!markdownBody) return "<p>بدون محتوا</p>";
    let text = markdownBody;
    text = text.replace(/\x3Cstyle[^\x3E]*\x3E[\s\S]*?\x3C\/style\x3E/gi, ' ');
    text = text.replace(/\x3Cxml[^\x3E]*\x3E[\s\S]*?\x3C\/xml\x3E/gi, ' ');
    text = text.replace(/\x3Cscript[^\x3E]*\x3E[\s\S]*?\x3C\/script\x3E/gi, ' ');
    text = text.replace(/\x3C!--[\s\S]*?--\x3E/g, ' ');
    text = text.replace(/!\[.*?\]\(.*?\)/g, ' ');
    text = text.replace(/\[(.*?)\]\(.*?\)/g, '$1');
    text = text.replace(/\x3Cbr\s*\/?\x3E/gi, '\n');
    text = text.replace(/\x3C\/p\x3E/gi, '\n');
    text = text.replace(/\x3C\/div\x3E/gi, '\n');
    text = text.replace(/\x3C[^\x3E]+\x3E/g, ' ');
    text = text.replace(/&nbsp;/gi, ' ');
    text = text.replace(/&quot;/gi, '"');
    text = text.replace(/&amp;/gi, '&');
    text = text.replace(/&lt;/gi, '\x3C');
    text = text.replace(/&gt;/gi, '\x3E');
    text = text.replace(/&#?[a-z0-9]+;/gi, ' ');
    text = text.replace(/[#*~_>]/g, '');
    text = text.replace(/[ \t]+/g, ' ').trim(); 
    text = text.replace(/ *[\r\n]+ */g, '\n');  
    text = text.replace(/\n+/g, '\n');          
    if (text.length > 350) {
        text = text.substring(0, 350) + '...';
    }
    text = text.replace(/\n/g, '<br/>');
    return `<p>${text}</p>`;
}

// --- PAGINATION LOGIC ---
const totalPages = page.lastPage;
const currentPage = page.currentPage;
const pageNumbers = [];
let lastAdded = 0;

for(let i = 1; i <= totalPages; i++) {
    if (i <= 5 || i > totalPages - 3 || Math.abs(i - currentPage) <= 1) {
        if (lastAdded > 0 && i - lastAdded > 1) {
            pageNumbers.push('...');
        }
        pageNumbers.push(i);
        lastAdded = i;
    }
}
