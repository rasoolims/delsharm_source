---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const allPosts = await getCollection('blog');
    const tags: string[] = [];
    
    // 1. Find all unique tags
    allPosts.forEach(post => {
        const title = post.data.title || "—";
        const postTags = post.data.tags ? [...post.data.tags] : [];
        
        if (title === "—" && !postTags.includes("سیاه‌مشق")) {
            postTags.push("سیاه‌مشق");
        }

        postTags.forEach(tag => {
            if (!tags.includes(tag)) tags.push(tag);
        });
    });

    // 2. Map tags to their respective posts
    return tags.map(tag => {
        const filteredPosts = allPosts.filter(post => {
            const postTags = post.data.tags ? [...post.data.tags] : [];
            const title = post.data.title || "—";
            if (title === "—" && !postTags.includes("سیاه‌مشق")) postTags.push("سیاه‌مشق");
            return postTags.includes(tag);
        }).sort((a, b) => {
            const dateA = (a.data && a.data.date) ? new Date(a.data.date).getTime() : 0;
            const dateB = (b.data && b.data.date) ? new Date(b.data.date).getTime() : 0;
            return dateB - dateA;
        });

        return {
            params: { tag },
            props: { posts: filteredPosts }
        };
    });
}

// Get the tag and posts from Astro's routing
const { tag } = Astro.params;
const { posts } = Astro.props;

// --- COMMENTS LOGIC ---
const allComments = await getCollection('comments');
const commentCounts: Record<string, number> = {};

allComments.forEach(comment => {
    const slug = comment.data.postSlug;
    commentCounts[slug] = (commentCounts[slug] || 0) + 1;
});

// --- HELPERS ---
function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}

function extractImage(bodyStr: string) {
    const imgRegex = /\x3Cimg[^\x3E]+src=["'](.*?)["']|!\[.*?\]\((.*?)\)/i;
    const match = bodyStr.match(imgRegex);
    return match ? (match[1] || match[2]) : null;
}

function generateExcerpt(markdownBody: string) {
    if (!markdownBody) return "<p>بدون محتوا</p>";
    let text = markdownBody;
    text = text.replace(/\x3Cstyle[^\x3E]*\x3E[\s\S]*?\x3C\/style\x3E/gi, ' ');
    text = text.replace(/\x3Cxml[^\x3E]*\x3E[\s\S]*?\x3C\/xml\x3E/gi, ' ');
    text = text.replace(/\x3Cscript[^\x3E]*\x3E[\s\S]*?\x3C\/script\x3E/gi, ' ');
    text = text.replace(/\x3C!--[\s\S]*?--\x3E/g, ' ');
    text = text.replace(/!\[.*?\]\(.*?\)/g, ' ');
    text = text.replace(/\[(.*?)\]\(.*?\)/g, '$1');
    text = text.replace(/\x3Cbr\s*\/?\x3E/gi, '\n');
    text = text.replace(/\x3C\/p\x3E/gi, '\n');
    text = text.replace(/\x3C\/div\x3E/gi, '\n');
    text = text.replace(/\x3C[^\x3E]+\x3E/g, ' ');
    text = text.replace(/&nbsp;/gi, ' ');
    text = text.replace(/&quot;/gi, '"');
    text = text.replace(/&amp;/gi, '&');
    text = text.replace(/&lt;/gi, '\x3C');
    text = text.replace(/&gt;/gi, '\x3E');
    text = text.replace(/&#?[a-z0-9]+;/gi, ' ');
    text = text.replace(/[#*~_>]/g, '');
    text = text.replace(/[ \t]+/g, ' ').trim(); 
    text = text.replace(/ *[\r\n]+ */g, '\n');  
    text = text.replace(/\n+/g, '\n');          
    if (text.length > 350) {
        text = text.substring(0, 350) + '...';
    }
    text = text.replace(/\n/g, '<br/>');
    return `<p>${text}</p>`;
}
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>دلشرم - نوشته‌های دارای برچسب: {tag}</title>
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="page-header">
            
            <div class="header-right">
                <a href="/delsharm/rss.xml" target="_blank" title="اشتراک RSS" class="rss-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 11a9 9 0 0 1 9 9"></path>
                        <path d="M4 4a16 16 0 0 1 16 16"></path>
                        <circle cx="5" cy="19" r="1"></circle>
                    </svg>
                    <span class="rss-text" dir="ltr">RSS</span>
                </a>
            </div>

<div class="header-center">
    <h1><a href="/delsharm/" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
    <p><a href="/delsharm/about" style="text-decoration: underline; color: inherit;">محمدصادق رسولی</a></p>
    
    <!-- Fast Links Section -->
    <div style="margin-top: 10px; display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; font-size: 0.85em;">
        <a href="/delsharm/tags/قفسه‌نوشت/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            قفسه‌نوشت
        </a>
        <a href="/delsharm/tags/سیاه‌مشق/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            سیاه‌مشق
        </a>
        <a href="/delsharm/tags/سفرنامهٔ نیویورک/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            سفرنامهٔ نیویورک
        </a>
        <a href="/delsharm/tags/شرابه‌های سفر/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            شرابه‌های سفر
        </a>
        <a href="/delsharm/tags/یادداشت‌های پراکنده/" style="color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 3px 10px; border-radius: 12px; text-decoration: none; font-weight: bold; transition: background 0.2s;">
            یادداشت‌های پراکنده
        </a>
    </div>
</div>

            <div class="header-left">
                <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم" style="margin: 0;">🌙</button>
            </div>

        </div>
        
        <div class="main-layout">
            <div class="content-area">
                <div class="section-title" style="margin-top: 0; margin-bottom: 30px;">
                    برچسب: <span style="color: #2980b9;">{tag}</span>
                </div>
                
                <div class="posts-grid">
                    {posts.map((post) => (
                        <div class="post-card">
                            {extractImage(post.body) && (
                                <a href={`/delsharm/blog/${post.id}/`}>
                                    <img src={extractImage(post.body)} class="card-img" alt="تصویر پست" />
                                </a>
                            )}
                            <div class="card-content" style="display: flex; flex-direction: column; flex-grow: 1;">
                                    <h2><a href={`/delsharm/blog/${post.id}/`}>{post.data.title}</a></h2>
                                    
                                    <div class="meta-row" style="margin-bottom: 15px;">
                                        {post.data.jalaliDate && <div class="date" style="margin-bottom: 0;">{post.data.jalaliDate}</div>}
                                    </div>

                                    <div class="excerpt-container" set:html={generateExcerpt(post.body)}></div>
                                    
                                    <!-- Notice the margin-top: auto; added here! -->
                                    <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 20px;">
                                        <a href={`/delsharm/blog/${post.id}/`} class="read-more" style="margin-top: 0;">ادامه مطلب ←</a>
                                        
                                        <a href={`/delsharm/blog/${post.id}/#comments-section`} class="comment-badge" style="position: relative; z-index: 20; text-decoration: none; font-size: 0.85em; color: #3498db; background: rgba(52, 152, 219, 0.1); padding: 2px 8px; border-radius: 12px; font-weight: bold;">
                                            💬 {commentCounts[post.id] ? toFa(commentCounts[post.id]) : '۰'} دیدگاه
                                        </a>

                                    </div>
                                </div>
                             </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
    
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        updateIcon();
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>