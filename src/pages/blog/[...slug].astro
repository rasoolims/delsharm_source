---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// --- COMMENTS LOGIC ---
const allComments = await getCollection('comments');
const filteredComments = allComments
    .filter(comment => comment.data.postSlug === post.id)
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

// Convert the JSON UTC timestamps into beautiful Jalali dates (Now with time!)
function formatJalali(dateObj: Date) {
    return new Intl.DateTimeFormat('fa-IR', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    }).format(dateObj);
}

function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}

// Smart URL formatter: adds https:// if the user forgets it!
function getValidUrl(url: string | undefined | null) {
    if (!url) return '';
    if (url.startsWith('http://') || url.startsWith('https://')) {
        return url;
    }
    return `https://${url}`;
}
---

<BlogPost {...post.data}>
  <Content />

    <div id="comments-section" class="comments-section">
      <h3 style="color: var(--text-heading); margin-bottom: 20px; font-size: 1.3em;">
        دیدگاه‌ها ({toFa(filteredComments.length)})
      </h3>

      <div class="comments-list">
        {filteredComments.map(comment => (
                <div class="comment-thread">
                    
                    {/* Visitor Comment */}
                    <div class="comment-item">
                        <div class="meta">
                            <strong>
                              {/* Check if the user provided a URL */}
                              {comment.data.url ? (
                                <a href={getValidUrl(comment.data.url)} target="_blank" rel="nofollow noopener noreferrer">
                                  {comment.data.name}
                                </a>
                              ) : (
                                comment.data.name
                              )}
                            </strong>
                            <span class="date">{formatJalali(comment.data.date)}</span>
                        </div>
                        <p>{comment.data.message}</p>
                    </div>

                    {/* Optional Admin Response */}
                    {comment.data.adminResponse && (
                        <div class="comment-item admin-reply">
                            <div class="meta">
                                <strong style="color: #2980b9;">محمدصادق رسولی</strong>
                                <span class="date">{formatJalali(comment.data.adminResponse.date)}</span>
                            </div>
                            <p>{comment.data.adminResponse.message}</p>
                        </div>
                    )}
                </div>
            ))}
        </div>

        {/* Private Message Notice */}
        <div style="background: rgba(241, 196, 15, 0.15); border-right: 4px solid #f1c40f; padding: 15px; margin-bottom: 20px; border-radius: 8px; font-size: 0.9em; color: var(--text-main);">
          <strong>پیام خصوصی:</strong> برای ارسال پیام خصوصی، لطفاً مستقیماً به ایمیل من (<strong>rasoolims</strong> در جیمیل) پیام دهید.
        </div>

        {/* Public Submission Form */}
        <form action="https://delsharm-comments.onrender.com/v2/entry/rasoolims/delsharm_source/main/comments" method="POST" class="comment-form">        
            {/* THIS IS THE CRITICAL FIX: fields[postSlug] */}
            <input type="hidden" name="fields[postSlug]" value={post.id} />
            
            <input type="text" name="fields[name]" placeholder="نام شما" required />
            <input type="email" name="fields[email]" dir="ltr" placeholder="ایمیل (اختیاری - منتشر نمی‌شود)" />
            {/* Changed from type="url" to type="text" to allow loose entry */}
            <input type="text" name="fields[url]" dir="ltr" placeholder="وب‌سایت (اختیاری - مثال: site.com)" />
            
            <textarea name="fields[message]" placeholder="دیدگاه خود را بنویسید..." rows="4" required></textarea>
        
        <button type="submit">ارسال دیدگاه</button>
      </form>
    </div>

    <style>
      .comments-section { margin-top: 50px; padding-top: 20px; border-top: 2px solid var(--border-color); }
      .comment-thread { margin-bottom: 25px; }
      
      .comment-item { background: var(--accent-bg); padding: 20px; border-radius: 8px; border-right: 4px solid var(--border-color); }
      .comment-item p { font-size: 0.85em !important; line-height: 1.6 !important; }
      .admin-reply { margin-right: 30px; margin-top: 10px; border-right: 4px solid #3498db; background: var(--bg-container); border: 1px solid var(--border-light); }
      .admin-reply p { font-style: italic; }
      
      .meta { display: flex; gap: 15px; align-items: center; margin-bottom: 10px; border-bottom: 1px dashed var(--border-light); padding-bottom: 10px;}
      
      /* New CSS for the linked names! */
      .meta strong { color: var(--text-heading); font-size: 1.1em; }
      .meta strong a { color: var(--text-heading); text-decoration: none; border-bottom: 1px dotted var(--text-muted); transition: color 0.2s, border-bottom-color 0.2s; }
      .meta strong a:hover { color: #3498db; border-bottom-color: #3498db; }
      
      .meta .date { font-size: 0.85em; color: var(--text-muted); }
      
      .comment-form { display: flex; flex-direction: column; gap: 15px; margin-top: 40px; background: var(--bg-container); padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid var(--border-light); }
      .comment-form input, .comment-form textarea { padding: 12px; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-body); color: var(--text-main); font-family: inherit; font-size: 1em; }
      .comment-form input:focus, .comment-form textarea:focus { outline: none; border-color: #3498db; }
      
      .comment-form button { padding: 12px 20px; background: #2c3e50; color: white; border: none; border-radius: 6px; font-size: 1em; font-weight: bold; cursor: pointer; transition: background 0.2s; font-family: inherit; align-self: flex-start; }
      .comment-form button:hover:not(:disabled) { background: #1a252f; }
      .comment-form button:disabled { opacity: 0.8; cursor: not-allowed; }
    </style>
</BlogPost>

<script is:inline>
      const form = document.querySelector('.comment-form');
      
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault(); // Stops the browser from leaving the page
          
          const btn = form.querySelector('button');
          const originalText = 'ارسال دیدگاه';
          
          // UI Feedback: Sending
          btn.innerText = 'در حال ارسال...';
          btn.style.backgroundColor = '#e67e22'; // Orange
          btn.disabled = true;

          // Package the form data
          const formData = new FormData(form);
          const params = new URLSearchParams(formData);

          try {
            // Send the data to your Render server invisibly
            const res = await fetch(form.action, {
              method: 'POST',
              body: params,
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
              }
            });

            if (res.ok) {
              // UI Feedback: Success
              btn.innerText = 'دیدگاه شما ثبت شد و پس از تایید نمایش داده می‌شود.';
              btn.style.backgroundColor = '#27ae60'; // Green
              form.reset(); // Clear the text boxes
              
              // Reset the button back to normal after 5 seconds
              setTimeout(() => {
                btn.disabled = false;
                btn.innerText = originalText;
                btn.style.backgroundColor = '';
              }, 5000);
            } else {
              // If Staticman throws an error, show it so we can debug
              const data = await res.json();
              alert("خطا: " + (data.errorCode || 'نامشخص'));
              btn.innerText = originalText;
              btn.style.backgroundColor = '';
              btn.disabled = false;
            }
          } catch (err) {
            alert("خطا در ارتباط با سرور. لطفاً تنظیمات اینترنت خود را بررسی کنید.");
            btn.innerText = originalText;
            btn.style.backgroundColor = '';
            btn.disabled = false;
          }
        });
      }
    </script>