---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// --- COMMENTS LOGIC ---
// Fetch all comments and filter them to only show the ones belonging to this specific post.id
const allComments = await getCollection('comments');
const filteredComments = allComments
  .filter(comment => comment.data.postSlug === post.id)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

// Convert the JSON UTC timestamps into beautiful Jalali dates
function formatJalali(dateObj: Date) {
    return new Intl.DateTimeFormat('fa-IR', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric' 
    }).format(dateObj);
}
---

<BlogPost {...post.data}>
	<Content />

    <div id="comments-section" class="comments-section">
      <h3 style="color: var(--text-heading); margin-bottom: 20px; font-size: 1.3em;">
        نظرات ({filteredComments.length})
      </h3>

      <div class="comments-list">
        {filteredComments.map(comment => (
          <div class="comment-thread">
            
            {/* Visitor Comment */}
            <div class="comment-item">
              <div class="meta">
                <strong>{comment.data.name}</strong>
                <span class="date">{formatJalali(comment.data.date)}</span>
              </div>
              <p>{comment.data.message}</p>
            </div>

            {/* Optional Admin Response */}
            {comment.data.adminResponse && (
              <div class="comment-item admin-reply">
                <div class="meta">
                  <strong style="color: #2980b9;">محمدصادق (نویسنده)</strong>
                  <span class="date">{formatJalali(comment.data.adminResponse.date)}</span>
                </div>
                <p>{comment.data.adminResponse.message}</p>
              </div>
            )}
          </div>
        ))}
      </div>

{/* Public Submission Form */}
<form action="https://delsharm-comments.onrender.com/v2/entry/rasoolims/delsharm_source/main/comments" method="POST" class="comment-form">        
        <input type="hidden" name="options[slug]" value={post.id} />
        
        
        <input type="text" name="fields[name]" placeholder="نام شما" required />
        <textarea name="fields[message]" placeholder="نظر خود را بنویسید..." rows="4" required></textarea>
        
        <button type="submit">ارسال نظر</button>
      </form>
    </div>

    <style>
      .comments-section { margin-top: 50px; padding-top: 20px; border-top: 2px solid var(--border-color); }
      .comment-thread { margin-bottom: 25px; }
      
      .comment-item { background: var(--accent-bg); padding: 20px; border-radius: 8px; border-right: 4px solid var(--border-color); }
      .admin-reply { margin-right: 30px; margin-top: 10px; border-right: 4px solid #3498db; background: var(--bg-container); border: 1px solid var(--border-light); }
      
      .meta { display: flex; gap: 15px; align-items: center; margin-bottom: 10px; border-bottom: 1px dashed var(--border-light); padding-bottom: 10px;}
      .meta strong { color: var(--text-heading); font-size: 1.1em; }
      .meta .date { font-size: 0.85em; color: var(--text-muted); }
      
      .comment-form { display: flex; flex-direction: column; gap: 15px; margin-top: 40px; background: var(--bg-container); padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid var(--border-light); }
      .comment-form input, .comment-form textarea { padding: 12px; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-body); color: var(--text-main); font-family: inherit; font-size: 1em; }
      .comment-form input:focus, .comment-form textarea:focus { outline: none; border-color: #3498db; }
      
      .comment-form button { padding: 12px 20px; background: #2c3e50; color: white; border: none; border-radius: 6px; font-size: 1em; font-weight: bold; cursor: pointer; transition: background 0.2s; font-family: inherit; align-self: flex-start; }
      .comment-form button:hover { background: #1a252f; }
    </style>
</BlogPost>

<script is:inline>
      const form = document.querySelector('.comment-form');
      
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault(); // Stops the browser from leaving the page
          
          const btn = form.querySelector('button');
          btn.innerText = 'در حال ارسال...'; // "Sending..."
          btn.disabled = true;

          // Package the form data
          const formData = new FormData(form);
          const params = new URLSearchParams(formData);

          try {
            // Send the data to your Render server invisibly
            const res = await fetch(form.action, {
              method: 'POST',
              body: params,
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
              }
            });

            if (res.ok) {
              // Replace the form with a success message!
              form.innerHTML = '<p style="color: #27ae60; font-weight: bold; background: rgba(39, 174, 96, 0.1); padding: 15px; border-radius: 8px; text-align: center;">نظر شما با موفقیت ثبت شد و پس از تایید نمایش داده می‌شود.</p>';
            } else {
              // If Staticman throws an error, show it so we can debug
              const data = await res.json();
              alert("خطا: " + (data.errorCode || 'نامشخص'));
              btn.innerText = 'ارسال نظر';
              btn.disabled = false;
            }
          } catch (err) {
            alert("خطا در ارتباط با سرور. لطفاً تنظیمات اینترنت خود را بررسی کنید.");
            btn.innerText = 'ارسال نظر';
            btn.disabled = false;
          }
        });
      }
    </script>