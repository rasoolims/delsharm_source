---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>درباره من | دلشرم</title>
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="container">
        <!-- Site Header and Theme Toggle -->
        <div class="page-header">
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم">🌙</button>
            <h1><a href="/delsharm/" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
        </div>
        
        <!-- Main Content Area -->
        <div class="single-post-container">
            <div class="section-title" style="border-bottom: none; text-align: center; margin-bottom: 30px;">
                درباره من
            </div>
            
            <div class="post-content-body">
                <p>
                    محمدصادق رسولی هستم. علاقه‌مند به ادبیات با تحصیلات غیرمرتبط در هوش مصنوعی. اگر دنبال عقبه‌ام می‌گردید، در 
                    <a href="https://www.linkedin.com/in/rasoolims/" target="_blank" rel="noopener noreferrer">صفحهٔ لینکدینم</a> موجود است.
                </p>

                <p>
                    پیش از این‌ها، از سال ۱۳۸۶ وب‌نوشت‌های «دلشرم» در بلاگفا بود که به خاطر مشکلات بلاگفا از بین رفت. بعد به «بیان» مهاجرت کردم و آن نیز اواخر ۱۴۰۴ تعطیل شد. ناچار شدم با استفاده از ترکیبی از هوش مصنوعی و برنامه‌نویسی، این وب‌نوشت‌ها را این‌گونه در فضای گیت‌هاب علم کنم. با کمک هوش مصنوعی بسیاری از مطالب و نظرات از دست‌رفته را بازیافتم، ولی این قافلهٔ عمر عجب می‌گذرد! بسیاری از مطالب قدیمی را نگه می‌دارم، هرچند که بعد از این همه سال تغییرات بسیاری اتفاق افتاده است و چه می‌شود گفت؟
                </p>

                <p>
                    برای پیام خصوصی، جیمیل من <strong>rasoolims</strong> است. پیام عمومی هم که پای هر مطلب میسر است.
                </p>

                <p>
                    این مطالب به صورت نیمچه‌دستی و بدون دسترسی به سامانه‌های رایج مدیریت محتوا، به شکل «شبه‌زغالی» مدیریت می‌شود؛ لذا از صبوری شما متشکریم.
                </p>
            </div>
            
            <!-- Return Button -->
            <div style="margin-top: 50px; text-align: right;">
                <a href="/delsharm/" class="read-more" style="display: inline-block;">← بازگشت به صفحه اصلی</a>
            </div>
        </div>
    </div>
    
    <!-- Dark Mode Script -->
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        updateIcon();
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>