---
// Import your global styles so it matches the rest of the site perfectly!
import '../styles/global.css';
---

<html lang="fa" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>درباره من | محمدصادق رسولی</title>
    
    <!-- Initialize dark mode immediately to prevent flashing -->
    <script is:inline>
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
  </head>
  <body>
    <!-- Using the same container class as your blog posts -->
    <div class="single-post-container">
      
      <!-- The same header used across your site -->
      <div class="page-header" style="margin-bottom: 30px;">
        <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم">🌙</button>
        <h1><a href="/delsharm/" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
        <p style="color: var(--text-muted); margin-top: 10px; font-size: 1.1em;">
          <a href="/delsharm/about" style="text-decoration: underline; color: inherit;">محمدصادق رسولی</a>
        </p>
      </div>
      
      <a href="/delsharm/" style="display: inline-block; margin-bottom: 20px; font-weight: bold;">← بازگشت به صفحه اصلی</a>
      
      <h2 style="border-bottom: 2px solid var(--border-color); padding-bottom: 15px; margin-top: 10px;">درباره من</h2>
      
      <!-- The post-content-body class ensures your font sizes and colors match the blog -->
      <div class="post-content-body">
        <p>
          سلام! من محمدصادق رسولی هستم... (متن بیوگرافی خود را اینجا بنویسید)
        </p>

        <h2 style="margin-top: 40px; margin-bottom: 15px;">راه‌های ارتباطی</h2>
        
        <ul>
          <li><strong>ایمیل:</strong> rasoolims [at] gmail [dot] com</li>
          <li><strong>لینکدین:</strong> <a href="#" target="_blank">پروفایل من</a></li>
        </ul>
      </div>
      
    </div>

    <!-- Script for the dark mode toggle button -->
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        
        if(themeBtn) {
            updateIcon();
            themeBtn.addEventListener('click', () => {
                document.documentElement.classList.toggle('dark-mode');
                const isDark = document.documentElement.classList.contains('dark-mode');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                updateIcon();
            });
        }
    </script>
  </body>
</html>